    {
      "parameters": {
        "fromEmail": "={{ $env.BUSINESS_OWNER_EMAIL || 'owner@rewindmediaevents.com' }}",
        "toEmail": "={{ $env.BUSINESS_OWNER_EMAIL || 'owner@rewindmediaevents.com' }}",
        "subject": "=New Inquiry: {{ $('Check Required Fields').item.json.firstName }} {{ $('Check Required Fields').item.json.lastName }} — {{ $('Check Required Fields').item.json.eventType || 'Unknown' }}",
        "text": "=New booking inquiry received.\n\nName: {{ $('Check Required Fields').item.json.firstName }} {{ $('Check Required Fields').item.json.lastName }}\nEmail: {{ $('Check Required Fields').item.json.email }}\nPhone: {{ $('Check Required Fields').item.json.phone || 'N/A' }}\nEvent Date: {{ $('Check Required Fields').item.json.eventDate }}\nEvent Type: {{ $('Check Required Fields').item.json.eventType || 'N/A' }}\nGuests: {{ $('Check Required Fields').item.json.guestCount || 'N/A' }}\nAddress: {{ $('Check Required Fields').item.json.eventAddress || 'N/A' }}\n\nNotes:\n{{ $('Check Required Fields').item.json.notes || $('Check Required Fields').item.json.message || '(none)' }}",
        "options": {}
