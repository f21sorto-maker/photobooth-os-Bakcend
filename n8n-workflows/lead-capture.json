        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"email\": \"{{ $('Check Required Fields').item.json.email.trim().toLowerCase() }}\",\n  \"name\": \"{{ $('Check Required Fields').item.json.firstName }} {{ $('Check Required Fields').item.json.lastName }}\",\n  \"status\": \"enabled\",\n  \"lists\": [{{ $env.LISTMONK_INQUIRY_LIST_ID || 1 }}],\n  \"preconfirm_subscriptions\": true\n}",
        "options": {}
      },
