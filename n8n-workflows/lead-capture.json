    {
      "parameters": {
        "jsCode": "// ─── ORIGIN VALIDATION ─────────────────────────────────────────────\n// PRODUCTION: Allow https://rewindmediaevents.com and www variant\n// LOCAL DEV:  Also allow null, localhost, 127.0.0.1, and file:// origins\n//\n// To lock down for production, change DEV_MODE to false.\n// ────────────────────────────────────────────────────────────────────\nconst DEV_MODE = true; // ← Set to false before deploying to production\n\nconst origin = ($input.first().json.headers?.origin\n             || $input.first().json.headers?.Origin\n             || '').trim();\n\nconst ALLOWED_PRODUCTION = [\n  'https://rewindmediaevents.com',\n  'https://www.rewindmediaevents.com'\n];\nconst ALLOWED_DEV = [\n  'null',                           // file:// sends Origin: null\n  '',                                // some browsers send no Origin\n];\nconst DEV_PATTERNS = [\n  /^https?:\\/\\/localhost(:\\d+)?$/,   // http://localhost:5500\n  /^https?:\\/\\/127\\.0\\.0\\.1(:\\d+)?$/, // http://127.0.0.1:8080\n  /^https?:\\/\\/0\\.0\\.0\\.0(:\\d+)?$/,   // http://0.0.0.0:3000\n];\n\nlet allowed = ALLOWED_PRODUCTION.includes(origin);\n\nif (!allowed && DEV_MODE) {\n  allowed = ALLOWED_DEV.includes(origin)\n         || DEV_PATTERNS.some(p => p.test(origin));\n}\n\nreturn [{ json: { originAllowed: allowed, origin, ...($input.first().json) } }];"
      },
      "id": "lc-0001-0001-0001-000000000009",
      "name": "Validate Origin",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [460, 300]
    },

    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "", "typeValidation": "strict" },
          "conditions": [
            {
              "leftValue": "={{ $json.originAllowed }}",
              "rightValue": "={{ true }}",
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
