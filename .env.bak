# ---------------------------------------------------------------------------
# LISTMONK
# ---------------------------------------------------------------------------
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=CHANGE_THIS_LISTMONK_PASSWORD

# ---------------------------------------------------------------------------
# BUSINESS CONFIG
# ---------------------------------------------------------------------------
BUSINESS_NAME="Rewind Media Events"
BUSINESS_OWNER_EMAIL=owner@photobooth.local
# Used as origin for travel distance calculations
