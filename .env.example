# =============================================================================
# PHOTO BOOTH BUSINESS OS — ENVIRONMENT CONFIGURATION
# =============================================================================
# 1. Copy this file to .env:  cp .env.example .env
# 2. Fill in ALL values (do not skip any)
# 3. Generate secrets with:   openssl rand -hex 32
# 4. Keep .env in a password manager backup — losing it locks you out
# =============================================================================

# ---------------------------------------------------------------------------
# DOMAIN & NETWORK
# ---------------------------------------------------------------------------
DOMAIN_BASE=photobooth.local

# ---------------------------------------------------------------------------
# POSTGRES — Shared Database
# ---------------------------------------------------------------------------
POSTGRES_USER=photobooth
POSTGRES_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE

# ---------------------------------------------------------------------------
# REDIS
# ---------------------------------------------------------------------------
REDIS_PASSWORD=GENERATE_A_STRONG_PASSWORD_HERE

# ---------------------------------------------------------------------------
# TWENTY CRM
# ---------------------------------------------------------------------------
# GENERATE WITH: openssl rand -hex 32
TWENTY_APP_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32

# ---------------------------------------------------------------------------
# INVOICE NINJA
# ---------------------------------------------------------------------------
# GENERATE WITH: openssl rand -base64 32
INVOICE_NINJA_APP_KEY=GENERATE_WITH_OPENSSL_RAND_BASE64_32

# ---------------------------------------------------------------------------
# DOCUSEAL
# ---------------------------------------------------------------------------
# GENERATE WITH: openssl rand -hex 64
DOCUSEAL_SECRET_KEY_BASE=GENERATE_WITH_OPENSSL_RAND_HEX_64
# Shared secret for webhook HMAC verification
DOCUSEAL_WEBHOOK_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32

# ---------------------------------------------------------------------------
# INVENTREE
# ---------------------------------------------------------------------------
# GENERATE WITH: openssl rand -hex 32
INVENTREE_SECRET_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
INVENTREE_ADMIN_USER=admin
INVENTREE_ADMIN_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD
INVENTREE_ADMIN_EMAIL=admin@photobooth.local

# ---------------------------------------------------------------------------
# N8N
# ---------------------------------------------------------------------------
# GENERATE WITH: openssl rand -hex 32
N8N_ENCRYPTION_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_THIS_N8N_PASSWORD
GENERIC_TIMEZONE=America/New_York

# ---------------------------------------------------------------------------
# LISTMONK
# ---------------------------------------------------------------------------
LISTMONK_ADMIN_USER=admin
LISTMONK_ADMIN_PASSWORD=CHANGE_THIS_LISTMONK_PASSWORD

# ---------------------------------------------------------------------------
# CAL.COM (Booking Calendar) — optional, can use Google Calendar via n8n instead
# ---------------------------------------------------------------------------
# GENERATE WITH: openssl rand -hex 32
CALCOM_NEXTAUTH_SECRET=GENERATE_WITH_OPENSSL_RAND_HEX_32
# GENERATE WITH: openssl rand -hex 32
CALCOM_ENCRYPTION_KEY=GENERATE_WITH_OPENSSL_RAND_HEX_32
# Optional — paste your Google Cloud OAuth JSON credentials string here
# to connect Cal.com to Google Calendar. Leave blank to skip.
CALCOM_GOOGLE_API_CREDENTIALS=

# ---------------------------------------------------------------------------
# BUSINESS CONFIG
# ---------------------------------------------------------------------------
BUSINESS_NAME="Rewind Media Events"
BUSINESS_OWNER_EMAIL=owner@photobooth.local
# Used as origin for travel distance calculations
BUSINESS_BASE_ADDRESS="Dayton, OH 45402"

# ---------------------------------------------------------------------------
# OPERATIONAL CONSTANTS
# ---------------------------------------------------------------------------
# Fallback gas price (used only if the EIA live feed is unreachable).
# The dashboard pulls the real number from the n8n "Update Gas Price (EIA)"
# workflow every 3 hours via https://automation.<DOMAIN>/webhook/gas-price.
GAS_PRICE_PER_GALLON=3.50

# Vehicle defaults — currently a 2024 Subaru Forester Wilderness
# (EPA combined 25 MPG, takes regular 87-octane unleaded).
VEHICLE_MPG=25
WEAR_TEAR_PER_MILE=0.60
HOURLY_LABOR_RATE=75.00

# ---------------------------------------------------------------------------
# EIA (Energy Information Administration) — live regional gas prices
# Sign up free in ~30 seconds: https://www.eia.gov/opendata/register.php
# State codes used by the EIA-878 weekly retail series:
#   SOH=Ohio  SCA=California  SFL=Florida  SNY=New York  STX=Texas
#   SPADD2=Midwest region (use this if your state isn't surveyed weekly)
# ---------------------------------------------------------------------------
EIA_API_KEY=YOUR_EIA_API_KEY
EIA_STATE_CODE=SOH


# ---------------------------------------------------------------------------
# EXTERNAL API KEYS
# ---------------------------------------------------------------------------
GOOGLE_MAPS_API_KEY=YOUR_GOOGLE_MAPS_API_KEY
BREVO_SMTP_USER=YOUR_BREVO_SMTP_USER
BREVO_SMTP_PASS=YOUR_BREVO_SMTP_PASSWORD

# ---------------------------------------------------------------------------
# CLOUDFLARE TUNNEL (Local Dev Only — remove on VPS)
# ---------------------------------------------------------------------------
# Create tunnel at: https://one.dash.cloudflare.com/ → Networks → Tunnels
# Name: photobooth-n8n
# Route: n8n.rewindmediaevents.com → http://n8n:5678
CLOUDFLARE_TUNNEL_TOKEN=YOUR_TUNNEL_TOKEN_HERE

# ---------------------------------------------------------------------------
# PUBLIC WEBHOOK (same in both local and VPS)
# ---------------------------------------------------------------------------
# This is the public URL that the live Cloudflare Pages site POSTs to.
# It must match the Cloudflare Tunnel ingress (local) or Nginx proxy (VPS).
N8N_PUBLIC_WEBHOOK_URL=https://n8n.rewindmediaevents.com

# ---------------------------------------------------------------------------
# APP-SPECIFIC IDS (Fill after Phase 3 manual setup)
# ---------------------------------------------------------------------------
# DocuSeal contract template ID
DOCUSEAL_TEMPLATE_ID=YOUR_DOCUSEAL_TEMPLATE_ID
# Listmonk mailing list IDs (integers, not UUIDs — find them in Listmonk → Lists)
LISTMONK_BOOKING_LIST_ID=2
LISTMONK_INQUIRY_LIST_ID=1

# ---------------------------------------------------------------------------
# INVOICE NINJA MariaDB
# ---------------------------------------------------------------------------
# GENERATE WITH: openssl rand -hex 16
NINJA_DB_ROOT_PASSWORD=GENERATE_WITH_OPENSSL_RAND_HEX_16
NINJA_DB_PASSWORD=GENERATE_WITH_OPENSSL_RAND_HEX_16
